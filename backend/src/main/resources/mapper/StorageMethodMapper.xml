<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xyz.lingview.dimstack.mapper.StorageMethodMapper">

    <resultMap id="StorageMethodResultMap" type="xyz.lingview.dimstack.domain.StorageMethod">
        <result property="uuid" column="uuid"/>
        <result property="user_uuid" column="user_uuid"/>
        <result property="name" column="name"/>
        <result property="type" column="type"/>
        <result property="config" column="config"/>
        <result property="status" column="status"/>
        <result property="created_at" column="created_at"/>
        <result property="updated_at" column="updated_at"/>
    </resultMap>

    <select id="selectByUuid" resultMap="StorageMethodResultMap">
        SELECT * FROM storage_method WHERE uuid = #{uuid}
    </select>

    <select id="selectByName" resultMap="StorageMethodResultMap">
        SELECT * FROM storage_method WHERE name = #{name} LIMIT 1
    </select>

    <select id="selectByType" resultMap="StorageMethodResultMap">
        SELECT * FROM storage_method WHERE type = #{type} AND status = 1 LIMIT 1
    </select>

    <select id="selectAll" resultMap="StorageMethodResultMap">
        SELECT * FROM storage_method ORDER BY created_at ASC
    </select>

    <insert id="insert" parameterType="xyz.lingview.dimstack.domain.StorageMethod">
        INSERT INTO storage_method (uuid, user_uuid, name, type, config, status)
        VALUES (#{uuid}, #{user_uuid}, #{name}, #{type}, #{config}, #{status})
    </insert>

    <update id="update" parameterType="xyz.lingview.dimstack.domain.StorageMethod">
        UPDATE storage_method
        SET name = #{name},
            type = #{type},
            config = #{config},
            status = #{status}
        WHERE uuid = #{uuid}
    </update>

    <update id="disable">
        UPDATE storage_method SET status = 0 WHERE uuid = #{uuid}
    </update>

    <update id="enable">
        UPDATE storage_method SET status = 1 WHERE uuid = #{uuid}
    </update>

    <delete id="deletePhysical">
        DELETE FROM storage_method WHERE uuid = #{uuid}
    </delete>
</mapper>