<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="xyz.lingview.dimstack.mapper.AnnouncementMapper">

    <select id="selectLatest" resultType="xyz.lingview.dimstack.domain.Announcement">
        SELECT * FROM announcement ORDER BY id DESC LIMIT 1
    </select>

    <insert id="insert">
        INSERT INTO announcement (content)
        VALUES (#{content})
    </insert>

</mapper>
